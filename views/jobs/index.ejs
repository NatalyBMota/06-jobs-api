<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title><%= pageTitle %></title>
</head>
<body>
  <h1>Jobs List</h1>
  <% if (message) { %><p><%= message %></p><% } %>

  <table>
    <tr>
      <th>Company</th>
      <th>Position</th>
      <th>Status</th>
      <th colspan="2"></th>
    </tr>

    <% jobs.forEach((job) => { %>
      <tr>
        <td><%= job.company %></td>
        <td><%= job.position %></td>
        <td><%= job.status %></td>
        <td><a href="/jobs/edit/<%= job._id %>">edit</a></td>
        <td>
          <form method="POST" action="/jobs/delete/<%= job._id %>" style="display: inline">
            <button>delete</button>
            <% if (locals._csrf) { %>
              <input type="hidden" name="_csrf" value="<%= locals._csrf %>" />
            <% } %>
          </form>
        </td>
      </tr>
    <% }) %>
  </table>

  <p><a href="/jobs/new">add job</a></p>

  <form method="POST" action="/auth/logout" style="display: inline">
    <button>log off</button>
    <% if (locals._csrf) { %>
      <input type="hidden" name="_csrf" value="<%= locals._csrf %>" />
    <% } %>
  </form>
</body>
</html>